/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model backup_configs {
  id                 Int                           @id @default(autoincrement())
  name               String                        @unique(map: "name") @db.VarChar(255)
  database_name      String                        @db.VarChar(255)
  backup_type        backup_configs_backup_type?   @default(full)
  compression        Boolean?                      @default(true)
  storage_type       backup_configs_storage_type?  @default(local)
  schedule_type      backup_configs_schedule_type? @default(manual)
  schedule_time      DateTime?                     @default(dbgenerated("'02:00:00'")) @db.Time(0)
  schedule_enabled   Boolean?                      @default(true)
  storage_config     String?                       @db.LongText
  retention_days     Int?                          @default(30)
  max_backups        Int?                          @default(10)
  notification_email String?                       @db.VarChar(255)
  created_at         DateTime?                     @default(now()) @db.Timestamp(0)
  updated_at         DateTime?                     @default(now()) @db.Timestamp(0)
  is_active          Boolean?                      @default(true)
  backup_history     backup_history[]

  @@index([database_name], map: "idx_database_name")
  @@index([is_active], map: "idx_is_active")
  @@index([schedule_type], map: "idx_schedule_type")
}

model backup_history {
