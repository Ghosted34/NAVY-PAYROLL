  @@index([config_id], map: "idx_config_id")
  @@index([database_name], map: "idx_database_name")
  @@index([expires_at], map: "idx_expires_at")
  @@index([started_at], map: "idx_started_at")
  @@index([status], map: "idx_status")
}

